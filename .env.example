# ── Servidor de chat (obligatorio) ──
COCINA_PORT=8090
COCINA_DB_PATH=./data/cocina.db
COCINA_JWT_SECRET=cambiar-en-produccion
COCINA_SERVER_URL=http://localhost:8090/api/v1

# Modo auth: local = solo chat (sin Identity). dual/identity requieren COCINA_IDENTITY_URL.
COCINA_AUTH_MODE=local

# Token opcional para guardar /admin desde internet (Cloudflare). No hace falta en localhost.
# COCINA_SETUP_TOKEN=

# ── Cocina Identity (opcional; dejar vacío para probar solo chat) ──
# COCINA_IDENTITY_URL=http://host.docker.internal:8080
# COCINA_IDENTITY_ISSUER=http://localhost:8080
# COCINA_IDENTITY_API_KEY=

# ── Cloudflare Tunnel (opcional; docker compose --profile tunnel up) ──
# Crear túnel en Zero Trust → Networks → Tunnels, mapear chat.tudominio.com → cocina-server:8090
# CLOUDFLARE_TUNNEL_TOKEN=

# URL pública tras configurar el túnel (también editable en http://localhost:8090/admin)
# COCINA_SERVER_URL=https://chat.tudominio.com/api/v1
